    <Action Name="ActualizarContador" Id="{056e9552-6c71-4125-8986-c07f209b5840}">
      <Implementation>
        <ST><![CDATA[Contador := Contador + 1;
AuxiliarContador := Contador - 4;]]></ST>
      </Implementation>
    </Action>
    <Action Name="ComprobarAltura" Id="{f3628f25-4a12-409f-b5ea-84f76c392954}">
      <Implementation>
        <ST><![CDATA[ListaAlturas[contador] := Codificador;]]></ST>
      </Implementation>
    </Action>
    <Action Name="IniciarContador" Id="{cffeacee-0dc1-4847-9499-e493e3acd434}">
      <Implementation>
        <ST><![CDATA[Contador := 1;]]></ST>
      </Implementation>
    </Action>
