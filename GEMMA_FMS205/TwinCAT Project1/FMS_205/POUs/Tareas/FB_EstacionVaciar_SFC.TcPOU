<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_EstacionVaciar_SFC" Id="{d3fe0cf5-15ac-423d-b520-9cbba896411a}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_EstacionVaciar_SFC

VAR_IN_OUT
	 TpoPreparacion: TIME;
     TpoMedidor: TIME;
END_VAR

VAR_INPUT
    // SFC-Flags
    SFCPause: BOOL;
    SFCReset: BOOL;
    
    // Indicadores de sincronizacion
    Ack: BOOL:= TRUE;
    Execute: BOOL;
	
	PlatoEmpujado: BOOL;
	PiezaRechazada: BOOL;
	PulsadorMarcha: BOOL;
	PiezaMedida: BOOL;
	Codificador: UINT;
    
END_VAR
VAR_OUTPUT
    // Indicadores de sincronizacion
    Done: BOOL;
    Ready: BOOL;
	EmpujaPlato : BOOL;
	RechazaPieza : BOOL;
	MedidorBaja: BOOL;
END_VAR
VAR
	Contador: INT;
    AuxiliarContador: INT;
	ListaAlturas : ARRAY[1..TAMANO_LISTA_PIEZAS] OF UINT;
END_VAR
]]></Declaration>
