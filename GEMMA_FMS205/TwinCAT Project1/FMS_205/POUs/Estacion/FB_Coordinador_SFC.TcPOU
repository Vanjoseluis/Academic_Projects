    <Folder Name="Acciones" Id="{f44a95ce-5ae9-43bf-a768-48c83e9a91a7}" />
    <Folder Name="Metodos" Id="{6a678e67-b353-425f-a6a9-6fd80138bb2c}" />
    <Action Name="Actualizar_Ciclo" Id="{7672e9a4-1636-48e3-9121-943c79590b09}" FolderPath="Acciones\">
      <Implementation>
        <ST><![CDATA[Nciclos := Nciclos + 1;
IF Nciclos >= 8 THEN // Si da una vuelta entera
   Nciclos := 0;
END_IF


// Tras 6 ciclos, la pieza puede ser desechada
IF Nciclos >= 5 THEN
   ListoParaRechazar := TRUE;
END_IF

// Tras 7 ciclos, la pieza puede ser descargada
IF  Nciclos >= 6 THEN
	ListoParaDescargar := TRUE;
END_IF

ListoParaMedir := TRUE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="Actualizar_FaltaMaterial" Id="{952bbbde-0d8d-4917-ac30-cfd32a5de3a5}">
      <Implementation>
        <ST><![CDATA[FaltaMaterial := FALSE;]]></ST>
      </Implementation>
    </Action>
    <Action Name="ActualizarUnidadesRealizadas" Id="{a435d1c6-0c42-453b-9c6b-2f59a6870f2e}" FolderPath="Acciones\">
      <Implementation>
        <ST><![CDATA[UnidadesRealizadas := UnidadesRealizadas + 1;
UnidadesPendientes := UnidadesPendientes - 1;]]></ST>
      </Implementation>
    </Action>
    <Action Name="Comparacion" Id="{cc2dfffd-ea49-44d6-9229-1803f5153340}" FolderPath="Acciones\">
      <Implementation>
        <ST><![CDATA[//Si esta listo para desechar
IF ListoParaRechazar THEN
   AuxNciclosDesechar := AjustarIndice(Nciclos - 4);
	ListadePiezas[AuxNciclosDesechar].EsBuena := FALSE;
							
	IF ListadePiezas[AuxNciclosDesechar].BienColocada THEN // Evaluacion de las condiciones exigidas
		ListadePiezas[AuxNciclosDesechar].EsBuena := EvaluarPieza(Indice := AuxNciclosDesechar,
																  LISTA_CONDICIONES := LISTA_CONDICIONES,
																  ListadePiezas := ListadePiezas,
																  ListaPiezasSolicitadas := ListaPiezasSolicitadas
																  );
	END_IF
END_IF

//Si esta listo para descargar		
IF ListoParaDescargar THEN	
	AuxNciclosDescargar := AjustarIndice(Nciclos - 5);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Method Name="EvaluarPieza" Id="{229fa35b-b26f-4178-be0f-17ef1fd8a899}" FolderPath="Metodos\">
      <Declaration><![CDATA[METHOD EvaluarPieza : BOOL
VAR_INPUT
	Indice : INT;
	LISTA_CONDICIONES : ARRAY[1..TAMANO_LISTA_CONDICIONES] OF CaracteristicasPieza;
END_VAR

VAR_IN_OUT
	ListadePiezas : ARRAY[1..TAMANO_LISTA_PIEZAS] OF Pieza; 
	ListaPiezasSolicitadas: ARRAY[1..TAMANO_LISTA_CONDICIONES] OF UINT; 
END_VAR

VAR
	ContadorComparacion : INT := 1;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[WHILE NOT ListadePiezas[Indice].EsBuena AND ContadorComparacion<7 DO 
	IF ListaPiezasSolicitadas[ContadorComparacion] > 0 THEN 
		IF MEMCMP (ADR(ListadePiezas[Indice].TipoPieza), 
			       ADR(LISTA_CONDICIONES[ContadorComparacion]), 
                   SIZEOF(LISTA_CONDICIONES[ContadorComparacion])) = 0 
       	THEN
			ListadePiezas[Indice].EsBuena := TRUE; 
            ListaPiezasSolicitadas[ContadorComparacion] := ListaPiezasSolicitadas[ContadorComparacion] - 1;
		END_IF
	END_IF
			ContadorComparacion := ContadorComparacion + 1;
END_WHILE

EvaluarPieza := ListadePiezas[Indice].EsBuena;]]></ST>
      </Implementation>
    </Method>
    <Action Name="UnidadesSolicitadas_aCero" Id="{a11b1288-f0fc-4a42-8e8e-acc865c04724}" FolderPath="Acciones\">
      <Implementation>
        <ST><![CDATA[ListaPiezasSolicitadas[1] := 0;
ListaPiezasSolicitadas[2] := 0;
ListaPiezasSolicitadas[3] := 0;
ListaPiezasSolicitadas[4] := 0;
ListaPiezasSolicitadas[5] := 0;
ListaPiezasSolicitadas[6] := 0;]]></ST>
      </Implementation>
    </Action>
    <Action Name="UnidadesSolicitadas_Iniciar" Id="{65409e14-37fb-41c0-bf2b-a49448fc8171}" FolderPath="Acciones\">
      <Implementation>
        <ST><![CDATA[UnidadesSolicitadas := 0;
 
//Suma de todas las iezas solicitadas
FOR AUX_Suma_Solicitadas := 1 TO TAMANO_LISTA_CONDICIONES DO
    UnidadesSolicitadas := UnidadesSolicitadas + ListaPiezasSolicitadas[AUX_Suma_Solicitadas];
END_FOR;

    UnidadesPendientes := UnidadesSolicitadas;
]]></ST>
      </Implementation>
    </Action>
