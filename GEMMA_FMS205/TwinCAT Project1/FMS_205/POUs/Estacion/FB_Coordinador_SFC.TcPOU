<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_Coordinador_SFC" Id="{b45996cd-eccc-4c22-9382-c6e15909ae18}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Coordinador_SFC

VAR CONSTANT
LISTA_CONDICIONES: ARRAY[1..TAMANO_LISTA_CONDICIONES] OF CaracteristicasPieza:=[(Claro:=FALSE, Metalico:=FALSE, Alta:=TRUE), //Negra alta
					(Claro:=TRUE,Metalico:=FALSE,Alta:=TRUE), //Blanca alta					
					(Claro:=TRUE, Metalico:=TRUE, Alta:=TRUE), //Metal alta
					(Claro:=FALSE, Metalico:=FALSE, Alta:=FALSE), //Negra baja
					(Claro:=TRUE, Metalico:=FALSE, Alta:=FALSE), //Blanca baja					
					(Claro:=TRUE, Metalico:=TRUE, Alta:=FALSE)]; //Metal baja
END_VAR

VAR_IN_OUT
	ListadePiezas: ARRAY[1..TAMANO_LISTA_PIEZAS] OF Pieza; // Array de tamaño 8 piezas 
	ListaPiezasSolicitadas: ARRAY[1..TAMANO_LISTA_CONDICIONES] OF UINT; // Array de 6 condiciones (blanca, negra y metálica, de momento)
	FaltaMaterial: BOOL;
END_VAR

VAR_INPUT
	  // SFC-Flags
    SFCPause: BOOL;
    SFCReset: BOOL;
    
    // Indicadores de sincronizacion
    Ack: BOOL := TRUE;
    Execute: BOOL;
    
    // Indicadores de control
    Resume: BOOL;
    StepByStep: BOOL;
	FinCiclo: BOOL;
    PiezaAPieza: BOOL;
    // Parametros de sincronizacion
    PaleSituado: BOOL;
	AlimentadorAvanzado: BOOL;
    PiezaCargada: BOOL;
	PlatoEmpujado: BOOL;
	PiezaMedida: BOOL;
    PiezaDescargada: BOOL;
    PiezaRechazada: BOOL;
    PaleTransferido: BOOL;
	PlatoRetrocedido: BOOL;
    
    // Parametros
    CondicionInicial: BOOL;

	//Variables auxiliares
	NCiclos: INT;
	AuxNciclosDesechar: INT := 1;
	AuxNciclosDescargar: INT := 1;
	ListoParaRechazar: BOOL := FALSE;
	ListoParaDescargar: BOOL := FALSE;
	ListoParaMedir: BOOL := FALSE;
	AUX_Suma_Solicitadas: UINT;
	
END_VAR
VAR_OUTPUT
	 // Indicadores de sincronizacion
    Done: BOOL;
    Ready: BOOL;
	Fallo: BOOL;
	FinPieza: BOOL;

    // Parametros de sincronizacion
    SituaPale: BOOL;
	AvanzaAlimentador: BOOL;
	EmpujaPlato: BOOL;
	MedidorMide: BOOL;
    CargaPieza: BOOL;
    DescargaPieza: BOOL;
    RechazaPieza: BOOL;
    TransfierePale: BOOL;
	RetrocederPlato: BOOL;
    
    // Salidas
    LamparaAlarma: BOOL;
    LamparaMarcha: BOOL;
	
	//Variables
	UnidadesSolicitadas: UINT := 1;
	UnidadesPendientes: UINT;
    UnidadesRealizadas: UINT; 
	
END_VAR
VAR

END_VAR]]></Declaration>
